<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AuraVision - Image AI Processing</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            background: white;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 600px;
            margin-bottom: 20px;
        }

        h2 {
            margin-top: 0;
            color: #333;
            font-weight: 600;
        }

        .subtitle {
            color: #666;
            font-size: 0.9em;
            margin-top: -10px;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            font-weight: bold;
            font-size: 0.9em;
            color: #555;
            margin-bottom: 5px;
        }

        input {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
        }

        button {
            background-color: #007bff;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
            width: 100%;
            margin-top: 10px;
        }

        button:hover {
            background-color: #0056b3;
        }

        .btn-secondary {
            background-color: #28a745;
        }

        .btn-secondary:hover {
            background-color: #218838;
        }

        .upload-zone {
            border: 2px dashed #ccc;
            padding: 30px;
            text-align: center;
            border-radius: 6px;
            cursor: pointer;
            background: #fafafa;
            margin: 15px 0;
            transition: border-color 0.2s;
        }

        .upload-zone:hover {
            border-color: #007bff;
        }

        .token-box {
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            padding: 10px;
            border-radius: 4px;
            font-family: monospace;
            font-size: 0.85em;
            word-break: break-all;
            max-height: 100px;
            overflow-y: auto;
            color: #495057;
            margin-top: 5px;
        }

        .hidden {
            display: none !important;
        }

        .error-message {
            color: #dc3545;
            font-size: 0.9em;
            margin-bottom: 15px;
            text-align: center;
        }

        .steps {
            margin-top: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .step {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 4px;
            font-size: 0.9em;
        }

        .step-bullet {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #ccc;
            display: inline-block;
        }

        .step.active {
            border-color: #007bff;
            background: #e6f2ff;
        }

        .step.active .step-bullet {
            background: #007bff;
        }

        .step.completed .step-bullet {
            background: #28a745;
        }
    </style>
</head>
<body>

    <!-- Auth Container -->
    <div class="container" id="authCard">
        <h2 id="authTitle">Image Processing System</h2>
        <div class="error-message" id="authError" style="display:none;"></div>
        
        <!-- Standard Login / Signup inputs -->
        <div id="credentials-fields">
            <div class="form-group">
                <label>Uploader Email</label>
                <input type="email" id="emailInput" value="testuser@example.com" placeholder="Email Address">
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" id="passwordInput" value="Password@123" placeholder="Password (Min 8 chars, 1 Upper, 1 Special, 1 Num)">
            </div>
        </div>

        <!-- Verification code field (hidden by default) -->
        <div id="verification-field" class="form-group hidden">
            <label>Verification Code (Sent to your Email)</label>
            <input type="text" id="verificationInput" placeholder="Enter 6-digit verification code">
        </div>

        <!-- Buttons -->
        <div id="action-buttons">
            <button id="loginBtn" onclick="login()">Log In & Initialize</button>
            <button id="registerBtn" class="btn-secondary hidden" onclick="signUp()">Create Account</button>
            <button id="confirmBtn" class="hidden" onclick="confirmSignUp()">Confirm Verification Code</button>
        </div>

        <!-- Toggle link -->
        <div style="margin-top: 20px; text-align: center; font-size: 0.9em;">
            <a href="#" id="toggleLink" onclick="toggleAuthMode(event)" style="color: #007bff; text-decoration: none; font-weight: bold;">Don't have an account? Sign Up</a>
        </div>
    </div>

    <!-- Dashboard Container -->
    <div class="container hidden" id="dashboardCard">
        <h2>Image Processing System</h2>

        <div class="upload-zone" id="dropzone" onclick="document.getElementById('fileInput').click()">
            <div style="font-size: 2.5em; margin-bottom: 10px;">📸</div>
            <p>Drag and drop an image here, or <strong>browse</strong></p>
            <input type="file" id="fileInput" accept="image/jpeg,image/png" class="hidden" onchange="handleFileSelect(event)">
        </div>

        <div class="form-group">
            <label>JWT ID Token</label>
            <div id="tokenDisplay" class="token-box">...</div>
        </div>

        <div class="steps">
            <div class="step" id="step1">
                <span class="step-bullet"></span>
                <span>Cognito JWT Token Authorized</span>
            </div>
            <div class="step" id="step2">
                <span class="step-bullet"></span>
                <span>Requesting S3 Pre-signed URL...</span>
            </div>
            <div class="step" id="step3">
                <span class="step-bullet"></span>
                <span>Uploading Image to S3...</span>
            </div>
            <div class="step" id="step4">
                <span class="step-bullet"></span>
                <span>Queueing SQS processing & AI labeling...</span>
            </div>
            <div class="step" id="step5">
                <span class="step-bullet"></span>
                <span>Success! Check your email for AI analysis.</span>
            </div>
        </div>
    </div>

    <script>
        const CONFIG = {
            userPoolId: "${user_pool_id}",
            clientId: "${app_client_id}",
            apiUrl: "${api_url}",
            region: "${aws_region}"
        };

        let idToken = "";
        let userEmail = "";
        let isSignUpMode = false;

        function toggleAuthMode(e) {
            if (e) e.preventDefault();
            const authTitle = document.getElementById("authTitle");
            const loginBtn = document.getElementById("loginBtn");
            const registerBtn = document.getElementById("registerBtn");
            const confirmBtn = document.getElementById("confirmBtn");
            const toggleLink = document.getElementById("toggleLink");
            const verificationField = document.getElementById("verification-field");
            const credentialsFields = document.getElementById("credentials-fields");
            const authError = document.getElementById("authError");

            authError.style.display = "none";

            if (isSignUpMode) {
                isSignUpMode = false;
                loginBtn.classList.remove("hidden");
                registerBtn.classList.add("hidden");
                confirmBtn.classList.add("hidden");
                verificationField.classList.add("hidden");
                credentialsFields.classList.remove("hidden");
                toggleLink.innerText = "Don't have an account? Sign Up";
            } else {
                isSignUpMode = true;
                loginBtn.classList.add("hidden");
                registerBtn.classList.remove("hidden");
                confirmBtn.classList.add("hidden");
                verificationField.classList.add("hidden");
                credentialsFields.classList.remove("hidden");
                toggleLink.innerText = "Already have an account? Sign In";
            }
        }

        async function login() {
            const email = document.getElementById("emailInput").value;
            const password = document.getElementById("passwordInput").value;
            const authError = document.getElementById("authError");

            authError.style.display = "none";

            try {
                const response = await fetch(`https://cognito-idp.$${CONFIG.region}.amazonaws.com/`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-amz-json-1.1",
                        "X-Amz-Target": "AWSCognitoIdentityProviderService.InitiateAuth"
                    },
                    body: JSON.stringify({
                        ClientId: CONFIG.clientId,
                        AuthFlow: "USER_PASSWORD_AUTH",
                        AuthParameters: {
                            USERNAME: email,
                            PASSWORD: password
                        }
                    })
                });

                const data = await response.json();

                if (data.AuthenticationResult) {
                    idToken = data.AuthenticationResult.IdToken;
                    userEmail = email;

                    document.getElementById("authCard").classList.add("hidden");
                    document.getElementById("dashboardCard").classList.remove("hidden");
                    document.getElementById("tokenDisplay").innerText = idToken;

                    updateStep("step1", "completed");
                } else {
                    throw new Error(data.message || "Invalid credentials.");
                }
            } catch (err) {
                authError.style.color = "red";
                authError.innerText = err.message;
                authError.style.display = "block";
            }
        }

        async function signUp() {
            const email = document.getElementById("emailInput").value;
            const password = document.getElementById("passwordInput").value;
            const authError = document.getElementById("authError");

            authError.style.display = "none";

            try {
                const response = await fetch(`https://cognito-idp.$${CONFIG.region}.amazonaws.com/`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-amz-json-1.1",
                        "X-Amz-Target": "AWSCognitoIdentityProviderService.SignUp"
                    },
                    body: JSON.stringify({
                        ClientId: CONFIG.clientId,
                        Username: email,
                        Password: password,
                        UserAttributes: [
                            { Name: "email", Value: email },
                            { Name: "custom:role", Value: "Intern" }
                        ]
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    authError.style.color = "green";
                    authError.innerText = "Sign up successful! Please check your email for a verification code.";
                    authError.style.display = "block";

                    // Transition to verification mode
                    document.getElementById("credentials-fields").classList.add("hidden");
                    document.getElementById("verification-field").classList.remove("hidden");
                    document.getElementById("registerBtn").classList.add("hidden");
                    document.getElementById("confirmBtn").classList.remove("hidden");
                } else {
                    throw new Error(data.message || "Sign up failed.");
                }
            } catch (err) {
                authError.style.color = "red";
                authError.innerText = err.message;
                authError.style.display = "block";
            }
        }

        async function confirmSignUp() {
            const email = document.getElementById("emailInput").value;
            const code = document.getElementById("verificationInput").value;
            const authError = document.getElementById("authError");

            authError.style.display = "none";

            try {
                const response = await fetch(`https://cognito-idp.$${CONFIG.region}.amazonaws.com/`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-amz-json-1.1",
                        "X-Amz-Target": "AWSCognitoIdentityProviderService.ConfirmSignUp"
                    },
                    body: JSON.stringify({
                        ClientId: CONFIG.clientId,
                        Username: email,
                        ConfirmationCode: code
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    authError.style.color = "green";
                    authError.innerText = "Account confirmed! You can now sign in.";
                    authError.style.display = "block";

                    // Transition back to login mode
                    isSignUpMode = true;
                    toggleAuthMode();
                    document.getElementById("emailInput").value = email;
                    document.getElementById("passwordInput").value = "";
                } else {
                    throw new Error(data.message || "Failed to confirm code.");
                }
            } catch (err) {
                authError.style.color = "red";
                authError.innerText = err.message;
                authError.style.display = "block";
            }
        }

        function updateStep(id, status) {
            const el = document.getElementById(id);
            el.className = "step";
            if (status) el.classList.add(status);
        }

        const dropzone = document.getElementById("dropzone");
        dropzone.addEventListener("dragover", (e) => { e.preventDefault(); dropzone.style.borderColor = "#007bff"; });
        dropzone.addEventListener("dragleave", () => { dropzone.style.borderColor = "#ccc"; });
        dropzone.addEventListener("drop", (e) => {
            e.preventDefault();
            dropzone.style.borderColor = "#ccc";
            if (e.dataTransfer.files.length) {
                processUpload(e.dataTransfer.files[0]);
            }
        });

        function handleFileSelect(e) {
            if (e.target.files.length) {
                processUpload(e.target.files[0]);
            }
        }

        async function processUpload(file) {
            updateStep("step2", "active");
            updateStep("step3", "");
            updateStep("step4", "");
            updateStep("step5", "");

            try {
                const res = await fetch(CONFIG.apiUrl, {
                    method: "POST",
                    headers: {
                        "Authorization": idToken,
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        filename: file.name,
                        contentType: file.type
                    })
                });

                const data = await res.json();

                if (!res.ok) throw new Error(data.error || "Failed to fetch URL");

                updateStep("step2", "completed");
                updateStep("step3", "active");

                const s3Res = await fetch(data.uploadUrl, {
                    method: "PUT",
                    headers: {
                        "Content-Type": file.type,
                        "x-amz-meta-uploader-email": userEmail
                    },
                    body: file
                });

                if (!s3Res.ok) throw new Error("S3 Upload failed");

                updateStep("step3", "completed");
                updateStep("step4", "active");

                setTimeout(() => {
                    updateStep("step4", "completed");
                    updateStep("step5", "completed");
                }, 3000);

            } catch (err) {
                alert("Pipeline failed: " + err.message);
                console.error(err);
            }
        }
    </script>
</body>
</html>
